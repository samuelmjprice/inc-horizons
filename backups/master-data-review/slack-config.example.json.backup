    "decisions": "#horizons-decisions"
  },
  "eventMapping": {
    "red_flag_created": "redFlags",
    "red_flag_resolved": "redFlags",
    "schedule_changed": "schedule",
    "call_sheet_changed": "production",
    "location_schedule_changed": "locations",
    "supplier_changed": "suppliers",
    "podcast_changed": "podcast",
    "document_uploaded": "documents",
    "document_missing": "documents",
    "decision_needed": "decisions",
    "content_capture_changed": "content",
    "capture_suggestion_accepted": "content",
    "capture_suggestion_deleted": "content",
    "cvent_conflict_found": "documents",
    "rehearsal_added": "production",
    "speaker_content_updated": "production"
  },
  "environmentVariables": [
    "SLACK_WEBHOOK_MAIN",
    "SLACK_WEBHOOK_RED_FLAGS",
    "SLACK_WEBHOOK_SCHEDULE",
    "SLACK_WEBHOOK_PRODUCTION",
    "SLACK_WEBHOOK_CONTENT",
